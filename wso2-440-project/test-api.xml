<?xml version="1.0" encoding="UTF-8"?>
<api xmlns="http://ws.apache.org/ns/synapse" name="MultiplyAPI" context="/multiply">
    <resource methods="POST" uri-template="/">
        <inSequence>
            <variable name="result" expression="${payload.number * 2}" type="INTEGER"/>
            <payloadFactory media-type="json">
                <format>
                    {
                        "input": ${payload.number},
                        "result": ${vars.result}
                    }
                </format>
            </payloadFactory>
            <respond/>
        </inSequence>
        <faultSequence>
            <log category="ERROR">
                <message>Error occurred: ${props.synapse.ERROR_MESSAGE}</message>
            </log>
            <payloadFactory media-type="json">
                <format>
                    {
                        "error": "Invalid input. Please provide a valid number."
                    }
                </format>
            </payloadFactory>
            <respond/>
        </faultSequence>
    </resource>
</api>
